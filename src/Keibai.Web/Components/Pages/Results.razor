@page "/jp/results"
@using System.Text
@inject IResultsReader Reader

@* 売却結果 explorer — past-auction outcomes with per-prefecture sale-rate/bid-ratio stats. Static SSR:
   the filter is a plain GET form; filters are read straight off HttpContext.Request.Query. *@

<PageTitle>売却結果 — Keibai</PageTitle>

<h1 class="h3 mb-3"><i class="bi bi-graph-up me-2"></i>売却結果 — past sale results</h1>

@if (_facets is not null)
{
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" action="/jp/results" class="row g-2 align-items-end">
                <div class="col-12 col-md-4">
                    <label for="pref" class="form-label mb-1">Prefecture 都道府県</label>
                    <select id="pref" name="pref" class="form-select">
                        <option value="">All prefectures</option>
                        @foreach (var p in _facets.Prefectures)
                        {
                            <option value="@p.Id" selected="@(p.Id == _pref)">@p.Name</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-4">
                    <label for="court" class="form-label mb-1">Court 裁判所</label>
                    <select id="court" name="court" class="form-select">
                        <option value="">All courts</option>
                        @foreach (var c in _facets.Courts)
                        {
                            <option value="@c.Id" selected="@(c.Id == _court)">@c.Name</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-2">
                    <label for="outcome" class="form-label mb-1">Outcome 結果</label>
                    <select id="outcome" name="outcome" class="form-select">
                        <option value="">All outcomes</option>
                        @foreach (var o in _facets.Outcomes)
                        {
                            <option value="@o" selected="@(o == _outcome)">@o</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1">
                        <i class="bi bi-funnel me-1"></i>Filter
                    </button>
                    <a href="/jp/results" class="btn btn-outline-secondary">Clear</a>
                </div>
            </form>
        </div>
    </div>
}

@if (_stats is { Count: > 0 })
{
    <h2 class="h5 mb-2">Sale-rate &amp; winning-bid ratio by prefecture</h2>
    <div class="table-responsive mb-4">
        <table class="table table-sm table-striped align-middle">
            <thead>
                <tr>
                    <th scope="col">Prefecture</th>
                    <th scope="col" class="text-end">Total</th>
                    <th scope="col" class="text-end">Sold</th>
                    <th scope="col" class="text-end">Sale rate</th>
                    <th scope="col" class="text-end">Median bid ratio</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var stat in _stats)
                {
                    <tr>
                        <td>@stat.PrefectureName</td>
                        <td class="text-end jp-num">@stat.Total</td>
                        <td class="text-end jp-num">@stat.Sold</td>
                        <td class="text-end jp-num">@stat.SaleRate.ToString("P0")</td>
                        <td class="text-end jp-num">@Display.Ratio(stat.MedianBidRatio)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (_page is not null)
{
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h2 class="h5 mb-0">Results</h2>
        <span class="text-muted small jp-num">@_page.Total result(s)</span>
    </div>

    @if (_page.Items.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle me-1"></i>No sale results match the current filter.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead>
                    <tr>
                        <th scope="col">Case 事件番号</th>
                        <th scope="col">Court 裁判所</th>
                        <th scope="col">Prefecture</th>
                        <th scope="col">開札</th>
                        <th scope="col" class="text-end">売却基準価額</th>
                        <th scope="col" class="text-end">売却価額</th>
                        <th scope="col" class="text-end">Ratio</th>
                        <th scope="col" class="text-end">Bids 入札</th>
                        <th scope="col">Outcome 結果</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in _page.Items)
                    {
                        var r = row.Result;
                        <tr>
                            <td>
                                @if (row.PropertyTracked && DetailLink(r.PropertyItemId) is { } href)
                                {
                                    <a href="@href">@(r.CaseLabel ?? "—")</a>
                                }
                                else
                                {
                                    @(r.CaseLabel ?? "—")
                                }
                            </td>
                            <td>@(row.CourtName ?? "—")</td>
                            <td>@row.PrefectureName</td>
                            <td class="jp-num">@Display.Date(r.OpeningDate)</td>
                            <td class="text-end jp-num">@Display.Yen(r.SaleStandardAmount)</td>
                            <td class="text-end jp-num">@Display.Yen(r.WinningBid)</td>
                            <td class="text-end jp-num">@Display.Ratio(row.BidRatio)</td>
                            <td class="text-end jp-num">@(r.BidCount?.ToString() ?? "—")</td>
                            <td>
                                @if (!string.IsNullOrEmpty(r.Outcome))
                                {
                                    <span class="badge text-bg-secondary">@r.Outcome</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (_page.TotalPages > 1)
        {
            <nav aria-label="Results pages" data-enhance-nav="false">
                <ul class="pagination">
                    <li class="page-item @(_page.HasPrevious ? "" : "disabled")">
                        <a class="page-link" href="@PageHref(_page.Page - 1)" tabindex="@(_page.HasPrevious ? null : "-1")"
                           aria-disabled="@(_page.HasPrevious ? "false" : "true")">
                            <i class="bi bi-chevron-left"></i> Prev
                        </a>
                    </li>
                    <li class="page-item disabled">
                        <span class="page-link jp-num">Page @_page.Page of @_page.TotalPages</span>
                    </li>
                    <li class="page-item @(_page.HasNext ? "" : "disabled")">
                        <a class="page-link" href="@PageHref(_page.Page + 1)" tabindex="@(_page.HasNext ? null : "-1")"
                           aria-disabled="@(_page.HasNext ? "false" : "true")">
                            Next <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
}

@code {
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private PagedResult<SaleResultView>? _page;
    private IReadOnlyList<PrefectureResultStats>? _stats;
    private ResultsFacets? _facets;

    private string? _pref;
    private string? _court;
    private string? _outcome;

    protected override async Task OnInitializedAsync()
    {
        _pref = Q("pref");
        _court = Q("court");
        _outcome = Q("outcome");

        var query = new ResultsQuery
        {
            PrefectureId = _pref,
            CourtId = _court,
            Outcome = _outcome,
            Page = ParsedPage(),
        };

        var ct = HttpContext?.RequestAborted ?? CancellationToken.None;
        var page = await Reader.SearchAsync(query, ct);
        var stats = await Reader.PrefectureStatsAsync(ct);
        var facets = await Reader.GetFacetsAsync(ct);

        _page = page;
        _stats = stats;
        _facets = facets;
    }

    /// <summary>A query value, treating empty/whitespace as null.</summary>
    private string? Q(string key)
    {
        var v = HttpContext?.Request.Query[key].ToString();
        return string.IsNullOrWhiteSpace(v) ? null : v;
    }

    /// <summary>The requested 1-based page (min 1), defaulting to 1.</summary>
    private int ParsedPage() =>
        int.TryParse(Q("page"), out var p) && p > 1 ? p : 1;

    /// <summary>Detail-page link for a tracked result: /jp/property/{court}/{unit} from "{court}:{unit}".</summary>
    private static string? DetailLink(string? propertyItemId)
    {
        if (string.IsNullOrEmpty(propertyItemId))
        {
            return null;
        }

        var i = propertyItemId.IndexOf(':');
        if (i <= 0 || i >= propertyItemId.Length - 1)
        {
            return null;
        }

        var court = propertyItemId[..i];
        var unit = propertyItemId[(i + 1)..];
        return $"/jp/property/{court}/{unit}";
    }

    /// <summary>Re-emit the current pref/court/outcome plus page=N as a results URL.</summary>
    private string PageHref(int page)
    {
        var qs = new StringBuilder("/jp/results?");
        void Add(string key, string? value)
        {
            if (!string.IsNullOrEmpty(value))
            {
                qs.Append(Uri.EscapeDataString(key)).Append('=').Append(Uri.EscapeDataString(value)).Append('&');
            }
        }

        Add("pref", _pref);
        Add("court", _court);
        Add("outcome", _outcome);
        qs.Append("page=").Append(page);
        return qs.ToString();
    }
}
