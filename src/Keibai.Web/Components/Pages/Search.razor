@page "/jp"
@using Keibai.Core.Ingestion
@inject IPropertyReader Reader
@inject IWatchlist Watchlist
@inject TimeProvider Time
@* Phase 3 search page — static SSR. Filters are a plain GET form (bookmarkable URLs); star/save are
   POST-Redirect-Get forms. No @rendermode, no EditForm. Render fields are assigned only after the
   awaits in OnInitializedAsync and guarded by @if so the pre-render pass never NREs. *@

<PageTitle>Search — 競売 Keibai</PageTitle>

<h1 class="h3 mb-3"><i class="bi bi-search me-2"></i>Search 物件</h1>

@if (_facets is { } facets && _page is { } results)
{
    var query = _query;
    var today = _today;
    var watched = _watched;

    <div class="card mb-4">
        <div class="card-body">
            <form method="get" action="/jp" class="row g-3">
                <div class="col-md-3">
                    <label for="pref" class="form-label">Prefecture</label>
                    <select id="pref" name="pref" class="form-select">
                        <option value="">All prefectures</option>
                        @foreach (var p in facets.Prefectures)
                        {
                            <option value="@p.Id" selected="@(query.PrefectureId == p.Id)">@Display.Prefecture(p.Id)</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="court" class="form-label">Court</label>
                    <select id="court" name="court" class="form-select">
                        <option value="">All courts</option>
                        @foreach (var group in facets.Courts.GroupBy(c => c.PrefectureId))
                        {
                            <optgroup label="@Display.Prefecture(group.Key)">
                                @foreach (var c in group)
                                {
                                    <option value="@c.Id" selected="@(query.CourtId == c.Id)">@c.Name</option>
                                }
                            </optgroup>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="type" class="form-label">Type</label>
                    <select id="type" name="type" class="form-select">
                        <option value="">All types</option>
                        @foreach (var t in _types)
                        {
                            <option value="@t" selected="@(query.Type == t)">@Display.TypeLabel(t)</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="status" class="form-label">Status</label>
                    <select id="status" name="status" class="form-select">
                        @foreach (var s in _statuses)
                        {
                            <option value="@s" selected="@(query.Status == s)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="min" class="form-label">Min price (¥)</label>
                    <input id="min" type="number" name="min" min="0" step="1" class="form-control"
                           value="@query.MinPrice" placeholder="0" />
                </div>
                <div class="col-md-3">
                    <label for="max" class="form-label">Max price (¥)</label>
                    <input id="max" type="number" name="max" min="0" step="1" class="form-control"
                           value="@query.MaxPrice" placeholder="∞" />
                </div>
                <div class="col-md-3">
                    <label for="from" class="form-label">開札 from</label>
                    <input id="from" type="date" name="from" class="form-control"
                           value="@(query.OpeningFrom?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-3">
                    <label for="to" class="form-label">開札 to</label>
                    <input id="to" type="date" name="to" class="form-control"
                           value="@(query.OpeningTo?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-8">
                    <label for="q" class="form-label">Address</label>
                    <input id="q" name="q" class="form-control" value="@query.Text"
                           placeholder="Free-text address search" />
                </div>
                <div class="col-md-4">
                    <label for="sort" class="form-label">Sort</label>
                    <select id="sort" name="sort" class="form-select">
                        @foreach (var so in _sorts)
                        {
                            <option value="@so" selected="@(query.Sort == so)">@so</option>
                        }
                    </select>
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="docs" name="docs" value="1"
                               checked="@query.HasDocuments" />
                        <label class="form-check-label" for="docs">
                            <i class="bi bi-file-earmark-pdf me-1"></i>Only properties with archived documents
                        </label>
                    </div>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-search me-1"></i>Search</button>
                    <a href="/jp" class="btn btn-outline-secondary">Clear</a>
                </div>
            </form>
        </div>
    </div>

    <div class="d-flex flex-wrap justify-content-between align-items-center mb-2 gap-2">
        <span class="text-muted">@results.Total propert@(results.Total == 1 ? "y" : "ies")</span>
        <form method="post" action="/jp/search/save@(SearchQueryString.ToQueryString(query))" class="d-flex gap-2">
            <input name="name" required placeholder="Name this search" class="form-control form-control-sm"
                   style="max-width: 16rem;" />
            <input type="hidden" name="return" value="/jp/watchlist" />
            <button type="submit" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-bookmark-plus me-1"></i>Save this search
            </button>
        </form>
    </div>

    @if (results.Items.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle me-1"></i>No properties match your filters.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead>
                    <tr>
                        <th scope="col"></th>
                        <th scope="col">Case no</th>
                        <th scope="col">Type</th>
                        <th scope="col">Prefecture</th>
                        <th scope="col">Address</th>
                        <th scope="col" class="text-end">売却基準価額</th>
                        <th scope="col" class="text-end">買受可能価額</th>
                        <th scope="col">Bid window</th>
                        <th scope="col">Deadline</th>
                        <th scope="col">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in results.Items)
                    {
                        var status = PropertySearch.DeriveStatus(item, today);
                        <tr>
                            <td>
                                <form method="post" action="/jp/watch" class="d-inline">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="return" value="@_returnUrl" />
                                    @if (watched.Contains(item.Id))
                                    {
                                        <button type="submit" class="btn btn-link p-0 text-warning" title="Unwatch">
                                            <i class="bi bi-star-fill"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-link p-0 text-secondary" title="Watch">
                                            <i class="bi bi-star"></i>
                                        </button>
                                    }
                                </form>
                            </td>
                            <td>
                                <a href="/jp/property/@item.CourtId/@item.SaleUnitId">@(item.Case?.Raw ?? "—")</a>
                                @if (item.LastArchivedAt is not null)
                                {
                                    <span class="badge text-bg-danger ms-1" title="Archived 3点セット (PDF) available">
                                        <i class="bi bi-file-earmark-pdf"></i>
                                    </span>
                                }
                            </td>
                            <td>@Display.TypeLabel(item.SaleCls)</td>
                            <td>@Display.Prefecture(item.PrefectureId)</td>
                            <td>@(item.DetailAddress ?? item.RawAddress ?? "—")</td>
                            <td class="text-end jp-num">@Display.Yen(item.SaleStandardAmount)</td>
                            <td class="text-end jp-num">@Display.Yen(item.MinimumBidAmount)</td>
                            <td class="jp-num">@Display.Date(item.BiddingStart)–@Display.Date(item.BiddingEnd)</td>
                            <td>
                                <span class="badge @Display.DeadlineClass(item.BiddingEnd, today)">
                                    @Display.Deadline(item.BiddingEnd, today)
                                </span>
                            </td>
                            <td>
                                <span class="badge @Display.StatusBadgeClass(status)">@Display.StatusLabel(status)</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (results.TotalPages > 1)
        {
            <nav aria-label="Search results pages" data-enhance-nav="false">
                <ul class="pagination">
                    <li class="page-item @(results.HasPrevious ? "" : "disabled")">
                        <a class="page-link" href="/jp@(SearchQueryString.ToQueryString(query, page: results.Page - 1))"
                           aria-label="Previous">
                            <i class="bi bi-chevron-left"></i> Prev
                        </a>
                    </li>
                    <li class="page-item disabled">
                        <span class="page-link">Page @results.Page of @results.TotalPages</span>
                    </li>
                    <li class="page-item @(results.HasNext ? "" : "disabled")">
                        <a class="page-link" href="/jp@(SearchQueryString.ToQueryString(query, page: results.Page + 1))"
                           aria-label="Next">
                            Next <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
}

@code {
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private static readonly SaleCls[] _types =
        [SaleCls.Land, SaleCls.Detached, SaleCls.Mansion, SaleCls.Other];
    private static readonly BiddingStatus[] _statuses = Enum.GetValues<BiddingStatus>();
    private static readonly PropertySort[] _sorts = Enum.GetValues<PropertySort>();

    private PropertyQuery _query = new();
    private DateOnly _today;
    private PagedResult<PropertyItem>? _page;
    private SearchFacets? _facets;
    private IReadOnlySet<string> _watched = new HashSet<string>();
    private string _returnUrl = "/jp";

    protected override async Task OnInitializedAsync()
    {
        if (HttpContext is not { } http)
        {
            return;
        }

        var ct = http.RequestAborted;
        var query = SearchQueryString.Parse(http.Request.Query);
        var today = JstClock.Today(Time);
        var page = await Reader.SearchAsync(query, ct);
        var facets = await Reader.GetFacetsAsync(ct);
        var watched = await Watchlist.WatchedIdsAsync(ct);

        _query = query;
        _today = today;
        _returnUrl = http.Request.Path + http.Request.QueryString;
        _page = page;
        _facets = facets;
        _watched = watched;
    }
}
