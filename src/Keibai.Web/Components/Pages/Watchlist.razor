@page "/jp/watchlist"
@inject IWatchlist Watch
@inject TimeProvider Time

@* Personal watchlist + saved searches. Static SSR: read in OnInitializedAsync, render forms that
   POST to the host's Post-Redirect-Get endpoints for the (few) write actions. *@

<PageTitle>ウォッチリスト / Watchlist — 競売 Keibai</PageTitle>

@if (_watched is not null && _saved is not null)
{
    var today = Keibai.Core.Ingestion.JstClock.Today(Time);

    <section class="mb-5">
        <h1 class="h3 mb-3">
            <i class="bi bi-star-fill text-warning me-1"></i>ウォッチ中の物件 / Watched Properties
            <span class="badge text-bg-secondary align-middle">@_watched.Count</span>
        </h1>

        @if (_watched.Count == 0)
        {
            <div class="alert alert-info" role="alert">
                ウォッチ中の物件はありません / No watched properties yet — star one from search.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th scope="col">事件番号 / Case</th>
                            <th scope="col">種別 / Type</th>
                            <th scope="col">都道府県 / Prefecture</th>
                            <th scope="col">所在地 / Address</th>
                            <th scope="col" class="text-end">売却基準価額 / Standard price</th>
                            <th scope="col">入札締切 / Deadline</th>
                            <th scope="col">開札 / Opening</th>
                            <th scope="col"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _watched)
                        {
                            <tr>
                                <td>
                                    <a href="/jp/property/@item.CourtId/@item.SaleUnitId">@(item.Case?.Raw ?? "—")</a>
                                </td>
                                <td>@Display.TypeLabel(item.SaleCls)</td>
                                <td>@Display.Prefecture(item.PrefectureId)</td>
                                <td>@(item.DetailAddress ?? item.RawAddress ?? "—")</td>
                                <td class="text-end jp-num">@Display.Yen(item.SaleStandardAmount)</td>
                                <td class="jp-num">@Display.Date(item.BiddingEnd)</td>
                                <td class="jp-num">@Display.Date(item.OpeningDate)</td>
                                <td class="text-end">
                                    <form method="post" action="/jp/watch" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="return" value="/jp/watchlist" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-star-fill me-1"></i>削除 / Remove
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section>
        <h2 class="h4 mb-2">
            <i class="bi bi-bookmark-star me-1"></i>保存した検索 / Saved Searches
            <span class="badge text-bg-secondary align-middle">@_saved.Count</span>
        </h2>
        <p class="text-muted small mb-3">
            <i class="bi bi-envelope me-1"></i>Saved searches feed the nightly 08:00 JST digest.
        </p>

        @if (_saved.Count == 0)
        {
            <div class="alert alert-info" role="alert">
                保存した検索はありません / No saved searches — save one from the search page.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th scope="col">名称 / Name</th>
                            <th scope="col">作成 / Created</th>
                            <th scope="col">最終実行 / Last run</th>
                            <th scope="col"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in _saved)
                        {
                            <tr>
                                <td>@s.Name</td>
                                <td class="jp-num">@s.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td class="jp-num">@(s.LastRunAt?.ToString("yyyy-MM-dd") ?? "never")</td>
                                <td class="text-end">
                                    <a href="/jp@(SearchQueryString.ToQueryString(s.Query))"
                                       class="btn btn-sm btn-outline-primary me-1">
                                        <i class="bi bi-play-fill me-1"></i>実行 / Run
                                    </a>
                                    <form method="post" action="/jp/search/delete" class="d-inline">
                                        <input type="hidden" name="id" value="@s.Id" />
                                        <input type="hidden" name="return" value="/jp/watchlist" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash me-1"></i>削除 / Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
}

@code {
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private IReadOnlyList<PropertyItem>? _watched;
    private IReadOnlyList<SavedSearch>? _saved;

    protected override async Task OnInitializedAsync()
    {
        var ct = HttpContext?.RequestAborted ?? CancellationToken.None;
        _watched = await Watch.WatchedPropertiesAsync(ct);
        _saved = await Watch.SavedSearchesAsync(ct);
    }
}
