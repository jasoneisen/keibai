@page "/jp/ops"
@using System.Globalization
@inject IOpsReader Reader
@* Ops dashboard — "confirm in 30 seconds that the system is healthy". Static SSR: one read in
   OnInitializedAsync, no interactivity. Bootstrap 5.3.7 utilities + a dependency-free sparkline. *@

<PageTitle>運用 / Ops — 競売 Keibai</PageTitle>

<h1 class="h3 mb-4"><i class="bi bi-activity me-2"></i>運用 / Ops</h1>

@if (_snap is { } snap)
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-3 mb-4">
        <div class="col">
            <div class="card h-100">
                <div class="card-body">
                    <h2 class="h6 text-muted"><i class="bi bi-hdd me-1"></i>ストレージ / Storage</h2>
                    @if (snap.MaxGigabytes <= 0)
                    {
                        <p class="fs-4 mb-1">@snap.StorageGb.ToString("N1") GB</p>
                        <span class="badge text-bg-secondary">監視オフ / watchdog off</span>
                    }
                    else
                    {
                        var pct = Math.Clamp(snap.StorageGb / snap.MaxGigabytes * 100, 0, 100);
                        var over = snap.StorageGb > snap.MaxGigabytes;
                        <p class="fs-4 mb-1">
                            @snap.StorageGb.ToString("N1") GB
                            <span class="fs-6 text-muted">of @snap.MaxGigabytes GB threshold</span>
                        </p>
                        <div class="progress" role="progressbar" aria-label="Storage used"
                             aria-valuenow="@((int)pct)" aria-valuemin="0" aria-valuemax="100">
                            <div class="progress-bar @(over ? "bg-danger" : "bg-success")"
                                 style="width:@pct.ToString("0.#", CultureInfo.InvariantCulture)%"></div>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100">
                <div class="card-body">
                    <h2 class="h6 text-muted"><i class="bi bi-stack me-1"></i>キュー / Queue depth</h2>
                    <p class="fs-4 mb-1">@(snap.QueueDepth?.ToString() ?? "—")</p>
                    <span class="text-muted small">pending durable envelopes</span>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100">
                <div class="card-body">
                    <h2 class="h6 text-muted"><i class="bi bi-bank me-1"></i>裁判所 / Courts</h2>
                    <p class="fs-4 mb-1">@snap.CourtsTotal <span class="fs-6 text-muted">total</span></p>
                    <span class="@(snap.DisabledCourts.Count > 0 ? "text-danger" : "text-muted") small">
                        @snap.DisabledCourts.Count disabled
                    </span>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100">
                <div class="card-body">
                    <h2 class="h6 text-muted"><i class="bi bi-calendar-day me-1"></i>本日 / Today <span class="text-muted">@snap.Today.Date</span></h2>
                    <dl class="row mb-0 small">
                        <dt class="col-7 fw-normal text-muted">アーカイブ / Archives</dt>
                        <dd class="col-5 mb-0 text-end">@snap.Today.PdfsArchived / @snap.Today.ArchiveAttempts</dd>
                        <dt class="col-7 fw-normal text-muted">失敗 / Failures</dt>
                        <dd class="col-5 mb-0 text-end @(snap.Today.ArchiveFailures > 0 ? "text-danger" : "")">@snap.Today.ArchiveFailures</dd>
                        <dt class="col-7 fw-normal text-muted">結果 / Results</dt>
                        <dd class="col-5 mb-0 text-end">@snap.Today.SaleResultsUpserted</dd>
                        <dt class="col-7 fw-normal text-muted">再確認 / Rechecks</dt>
                        <dd class="col-5 mb-0 text-end">@snap.Today.RechecksPerformed</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    @if (snap.DisabledCourts.Count > 0)
    {
        <div class="alert alert-danger" role="alert">
            <h2 class="h6 alert-heading"><i class="bi bi-exclamation-octagon me-1"></i>無効化された裁判所 / Disabled courts</h2>
            <ul class="mb-0">
                @foreach (var court in snap.DisabledCourts)
                {
                    <li>
                        <strong>@court.Name</strong> <span class="text-muted">(@court.Id)</span>
                        @if (!string.IsNullOrWhiteSpace(court.Reason))
                        {
                            <span>— @court.Reason</span>
                        }
                        @if (court.At is { } at)
                        {
                            <span class="text-muted small"> · @at.ToString("yyyy-MM-dd HH:mm")</span>
                        }
                    </li>
                }
            </ul>
        </div>
    }

    <h2 class="h5 mb-2"><i class="bi bi-map me-2"></i>都道府県別ステータス / Prefecture health</h2>
    <div class="table-responsive mb-4">
        <table class="table table-sm table-hover align-middle">
            <thead>
                <tr>
                    <th scope="col"></th>
                    <th scope="col">都道府県 / Prefecture</th>
                    <th scope="col">最終取得 / Last sweep</th>
                    <th scope="col" class="text-end">取得 / Found</th>
                    <th scope="col" class="text-end">新規 / New</th>
                    <th scope="col" class="text-end">エラー / Errors</th>
                    <th scope="col"></th>
                    <th scope="col">履歴 / History</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in snap.Prefectures)
                {
                    <tr>
                        <td><span class="badge @HealthBadge(row.Health)" title="@row.Health">●</span></td>
                        <td>@row.PrefectureName</td>
                        <td>@(row.LastSweepAt?.ToString("MM-dd HH:mm") ?? "—")</td>
                        <td class="text-end jp-num">@row.ItemsFound</td>
                        <td class="text-end jp-num">@row.ItemsNew</td>
                        <td class="text-end jp-num @(row.Errors > 0 ? "text-danger fw-semibold" : "")">@row.Errors</td>
                        <td>
                            @if (row.Blocked)
                            {
                                <span class="badge text-bg-danger">BLOCKED</span>
                            }
                        </td>
                        <td>
                            @if (row.History.Count > 0)
                            {
                                var max = row.History.Max();
                                <span class="sparkline text-primary">
                                    @foreach (var v in row.History)
                                    {
                                        <span style="height:@Pct(v, max)%"></span>
                                    }
                                </span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <h2 class="h5 mb-2"><i class="bi bi-bell me-2"></i>最近のアラート / Recent alerts</h2>
    @if (snap.RecentAlerts.Count == 0)
    {
        <p class="text-muted">アラートなし / No recent alerts — all quiet.</p>
    }
    else
    {
        <div class="list-group mb-4">
            @foreach (var alert in snap.RecentAlerts)
            {
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-center">
                        <span>
                            <span class="badge @SeverityBadge(alert.Severity) me-2">@alert.Severity</span>
                            <strong>@alert.Title</strong>
                        </span>
                        <span class="text-muted small">@alert.At.ToString("yyyy-MM-dd HH:mm")</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(alert.Body))
                    {
                        <div class="text-muted small mt-1">@alert.Body</div>
                    }
                </div>
            }
        </div>
    }
}

@code {
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private OpsSnapshot? _snap;

    protected override async Task OnInitializedAsync()
    {
        var snap = await Reader.GetAsync(HttpContext?.RequestAborted ?? default);
        _snap = snap;
    }

    private static string HealthBadge(string health) => health switch
    {
        "green" => "text-bg-success",
        "amber" => "text-bg-warning",
        "red" => "text-bg-danger",
        _ => "text-bg-secondary",
    };

    private static string SeverityBadge(AlertSeverity severity) => severity switch
    {
        AlertSeverity.Critical => "text-bg-danger",
        AlertSeverity.Warning => "text-bg-warning",
        _ => "text-bg-secondary",
    };

    // Scale a value to the row's max for the sparkline bar height (max → 100%, guard divide-by-zero).
    private static string Pct(int value, int max) =>
        max <= 0 ? "1" : ((double)value / max * 100).ToString("0.#", CultureInfo.InvariantCulture);
}
